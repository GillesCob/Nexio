// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")

}

enum Role {
  guest
  admin
}

enum JobOfferStatus {
  wishlist
  applied
  interview
  offer
  rejected
  accepted
}

enum ContactStatus {
  to_contact
  contacted
  replied
  meeting_scheduled
  follow_up
  closed
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  role         Role     @default(guest)
  refreshToken String?
  createdAt    DateTime @default(now())

  jobOffers           JobOffer[]
  contacts            Contact[]
  passwordResetTokens PasswordResetToken[]
  linkedInSnapshots   LinkedInSnapshot[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model JobOffer {
  id          String         @id @default(cuid())
  title       String
  company     String
  description String?
  stack       String[]
  salary      String?
  remote      Boolean        @default(false)
  location    String?
  url         String?
  status      JobOfferStatus @default(wishlist)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  score        Int?
  scoreMatches String[]
  scoreGaps    String[]
  scoreComment String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  contacts Contact[]
}

model Company {
  id          String    @id @default(cuid())
  name        String
  description String?
  sector      String?
  size        String?
  linkedinUrl String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  contacts Contact[]
}

model Contact {
  id          String        @id @default(cuid())
  name        String
  company     String?
  linkedinUrl String?
  jobTitle    String?
  status      ContactStatus @default(to_contact)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobOfferId String?
  jobOffer   JobOffer? @relation(fields: [jobOfferId], references: [id], onDelete: SetNull)

  companyId String?
  companyRef Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  messages Message[]
}

model Message {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model LinkedInSnapshot {
  id                         String   @id @default(cuid())
  weekLabel                  String
  impressions                Int
  impressionsVariation       Int
  followers                  Int
  followersVariation         Int
  profileViews               Int
  profileViewsVariation      Int
  searchAppearances          Int
  searchAppearancesVariation Int
  postsCount                 Int
  commentsCount              Int
  createdAt                  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}
